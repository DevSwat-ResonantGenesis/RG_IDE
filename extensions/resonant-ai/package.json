{
  "name": "resonant-ai",
  "displayName": "DevSwat AI",
  "description": "DevSwat IDE AI Assistant — local agentic coding with 59 tools",
  "icon": "media/icon.png",
  "version": "0.1.0",
  "publisher": "resonant-genesis",
  "engines": {
    "vscode": "^1.110.0"
  },
  "enabledApiProposals": [
    "defaultChatParticipant",
    "chatParticipantAdditions",
    "chatProvider"
  ],
  "main": "./out/extension",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "resonant-ai-sidebar",
          "title": "DevSwat AI",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "resonant-ai-sidebar": [
        {
          "type": "webview",
          "id": "resonant.chatView",
          "name": "DevSwat AI Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "resonant.openChat",
        "title": "Open DevSwat AI Chat",
        "category": "DevSwat AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "resonant.newConversation",
        "title": "New Conversation",
        "category": "DevSwat AI"
      },
      {
        "command": "resonant.login",
        "title": "Sign In",
        "category": "DevSwat AI"
      },
      {
        "command": "resonant.logout",
        "title": "Sign Out",
        "category": "DevSwat AI"
      },
      {
        "command": "resonant.setApiKey",
        "title": "Set API Key",
        "category": "DevSwat AI"
      },
      {
        "command": "resonant.openProfile",
        "title": "Profile & Account Settings",
        "category": "DevSwat AI",
        "icon": "$(account)"
      },
      {
        "command": "resonant.openSettingsPanel",
        "title": "Settings Panel",
        "category": "DevSwat AI",
        "icon": "$(settings-gear)"
      },
      {
        "command": "resonant.refreshProviders",
        "title": "Refresh Providers & Agents",
        "category": "DevSwat AI",
        "icon": "$(refresh)"
      },
      {
        "command": "resonant.toggleChatView",
        "title": "Toggle DevSwat AI Chat",
        "category": "DevSwat AI",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "resonant.localLLM.testConnection",
        "title": "Local LLM: Test Connection",
        "category": "DevSwat AI",
        "icon": "$(plug)"
      },
      {
        "command": "resonant.localLLM.listModels",
        "title": "Local LLM: List Available Models",
        "category": "DevSwat AI",
        "icon": "$(list-unordered)"
      },
      {
        "command": "resonant.localLLM.selectModel",
        "title": "Local LLM: Select Model",
        "category": "DevSwat AI",
        "icon": "$(symbol-enum)"
      },
      {
        "command": "resonant.localLLM.toggle",
        "title": "Local LLM: Toggle On/Off",
        "category": "DevSwat AI",
        "icon": "$(toggle-on)"
      }
    ],
    "chatParticipants": [
      {
        "id": "resonant-genesis.resonant-ai.default",
        "name": "assistant",
        "fullName": "DevSwat AI",
        "description": "DevSwat AI Assistant",
        "isDefault": true,
        "modes": ["agent", "ask", "edit"],
        "locations": ["panel", "terminal", "editor"]
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "resonant",
        "displayName": "Resonant Genesis"
      }
    ],
    "keybindings": [
      {
        "command": "resonant.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "authentication": [
      {
        "id": "resonant-genesis",
        "label": "Resonant Genesis"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "resonant.openChat", "when": "true" },
        { "command": "resonant.login", "when": "true" },
        { "command": "resonant.logout", "when": "true" },
        { "command": "resonant.openProfile", "when": "true" }
      ]
    },
    "configuration": {
      "title": "DevSwat AI",
      "properties": {
        "resonant.apiUrl": {
          "type": "string",
          "default": "https://dev-swat.com",
          "description": "Backend API URL"
        },
        "resonant.maxToolLoops": {
          "type": "number",
          "default": 15,
          "description": "Maximum tool execution loops per message"
        },
        "resonant.localLLM.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable local LLM mode — connect to Ollama or any OpenAI-compatible server running on your machine. No internet or API keys needed."
        },
        "resonant.localLLM.url": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Local LLM server URL. Ollama default: http://localhost:11434, LM Studio: http://localhost:1234, llama.cpp: http://localhost:8080"
        },
        "resonant.localLLM.model": {
          "type": "string",
          "default": "",
          "description": "Local model name (e.g. llama3.1:8b, codellama:13b, deepseek-coder:6.7b, qwen2.5-coder:7b). Leave empty to auto-detect."
        },
        "resonant.localLLM.contextLength": {
          "type": "number",
          "default": 32768,
          "description": "Context window size for local model (tokens). Ollama default: 32768."
        }
      }
    }
  },
  "extensionPack": [],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0"
  }
}
